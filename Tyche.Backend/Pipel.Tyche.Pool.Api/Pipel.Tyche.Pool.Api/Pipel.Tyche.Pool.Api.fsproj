<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Pool.fs" />
        <Compile Include="PoolApplicationMapper.fs" />
        <Compile Include="FindPoolsUseCase.fs" />
        <Compile Include="RegistersForRepositories.fs" />
        <Compile Include="RegistersForMappers.fs" />
        <Compile Include="RegistersForUseCases.fs" />
        <Compile Include="RegistersForDatabases.fs" />
        <Compile Include="RegistersForHelpers.fs" />
        <Compile Include="WebApplicationInit.fs" />
        <Compile Include="WebApplicationBuilderInit.fs" />
        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
      <Content Include=".dockerignore" />
      <Content Include="Dockerfile" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\Pipel.Tyche.Pool\Pipel.Tyche.Pool\Pipel.Tyche.Pool.fsproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="AWSSDK.Extensions.NETCore.Setup" Version="3.7.1" />
      <PackageReference Update="FSharp.Core" Version="6.0.3" />
    </ItemGroup>

</Project>
