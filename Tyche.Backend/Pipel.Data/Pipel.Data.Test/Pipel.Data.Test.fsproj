<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>

        <IsPackable>false</IsPackable>
        <GenerateProgramFile>false</GenerateProgramFile>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Data.fs" />
        <Compile Include="DemoData.fs" />
        <Compile Include="QueryStringTests.fs" />
        <Compile Include="QueryUseCasesTests.fs" />
        <Compile Include="ModifyUseCasesTests.fs" />
        <Compile Include="EntityFrameworkCore\FindTests.fs" />
        <Compile Include="EntityFrameworkCore\FindAndPaginateTests.fs" />
        <Compile Include="EntityFrameworkCore\ModifyTests.fs" />
        <Compile Include="EntityFrameworkCore\UnitOfWorkTests.fs" />
        <Compile Include="Program.fs" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="6.0.0" />
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.0.0" />
        <PackageReference Include="Moq" Version="4.16.1" />
        <PackageReference Include="xunit" Version="2.4.1" />
        <PackageReference Include="xunit.runner.visualstudio" Version="2.4.3">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
        <PackageReference Include="coverlet.collector" Version="3.1.0">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Pipel.Data\Pipel.Data.fsproj" />
    </ItemGroup>

</Project>
