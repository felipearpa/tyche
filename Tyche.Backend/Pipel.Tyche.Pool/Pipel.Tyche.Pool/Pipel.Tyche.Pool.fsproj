<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <WarnOn>3390;$(WarnOn)</WarnOn>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Data\PoolLayout.fs" />
        <Compile Include="Data\Pool.fs" />
        <Compile Include="Data\PoolRepository.fs" />
        <Compile Include="Data\PoolGambler.fs" />
        <Compile Include="Data\PoolGamblerRepository.fs" />
        <Compile Include="Domain\PoolLayout.fs" />
        <Compile Include="Domain\Pool.fs" />
        <Compile Include="Domain\Gambler.fs" />
        <Compile Include="Domain\PoolGambler.fs" />
        <Compile Include="UseCases\FindPoolsUseCase.fs" />
        <Compile Include="UseCases\FindPoolsGamblersUseCase.fs" />
        <Compile Include="PoolDomainMapper.fs" />
        <Compile Include="PoolGamblerDomainMapper.fs" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\Pipel.Data.DynamoDb\Pipel.Data.DynamoDb\Pipel.Data.DynamoDb.fsproj" />
      <ProjectReference Include="..\..\Pipel.Data\Pipel.Data\Pipel.Data.fsproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Update="FSharp.Core" Version="6.0.5" />
    </ItemGroup>

</Project>
