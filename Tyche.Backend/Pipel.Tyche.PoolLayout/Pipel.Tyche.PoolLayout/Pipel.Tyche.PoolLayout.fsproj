<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <WarnOn>3390;$(WarnOn)</WarnOn>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Data\PoolLayout.fs" />
        <Compile Include="Data\PoolLayoutRepository.fs" />
        <Compile Include="Domain\PoolLayout.fs" />
        <Compile Include="UseCases\FindActivePoolsLayoutsUseCase.fs" />
        <Compile Include="PoolLayoutDomainMapper.fs" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\Pipel.Data.DynamoDb\Pipel.Data.DynamoDb\Pipel.Data.DynamoDb.fsproj" />
      <ProjectReference Include="..\..\Pipel.Data\Pipel.Data\Pipel.Data.fsproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Update="FSharp.Core" Version="6.0.3" />
    </ItemGroup>

</Project>
