<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Tyche" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/nord9</item>
        <item name="colorPrimaryVariant">@color/nord9_variant</item>
        <item name="colorOnPrimary">@color/nord0</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/nord10</item>
        <item name="colorSecondaryVariant">@color/nord10_variant</item>
        <item name="colorOnSecondary">@color/nord0</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/nord6</item>
        <item name="colorSurface">@color/nord5</item>
        <item name="colorError">@color/nord11</item>
        <item name="colorOnBackground">@color/nord0</item>
        <item name="colorOnSurface">@color/nord0</item>
        <item name="colorOnError">@color/nord6</item>
    </style>

    <style name="Theme.Tyche.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Tyche.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Tyche.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>