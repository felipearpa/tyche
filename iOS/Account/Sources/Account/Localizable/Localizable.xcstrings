            "value": "Continuar"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuar"
          }
        }
      }
    },
    "email_label": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Email"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Correo electrónico"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Correo electrónico"
          }
        }
      }
    },
    "email_validation_failure_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Must be a valid email"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Debe ser un correo electrónico válido"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Debe ser un correo electrónico válido"
          }
        }
      }
    },
    "google_sign_in_account_exists_failure_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Account already exists"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cuenta ya existe"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "La cuenta ya existe"
          }
        }
      }
    },
    "google_sign_in_account_exists_failure_reason": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An account with this email already exists using a different sign-in method"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe una cuenta con este correo usando otro método de inicio de sesión"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe una cuenta con este correo usando otro método de inicio de sesión"
          }
        }
      }
    },
    "google_sign_in_account_exists_failure_recovery_suggestion": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with the original method to link your Google account"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesión con el método original para vincular tu cuenta de Google"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesión con el método original para vincular tu cuenta de Google"
          }
        }
      }
    },
    "google_sign_in_invalid_credential_failure_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Google sign-in failed"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Falló el inicio con Google"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Falló el inicio con Google"
          }
        }
      }
    },
    "google_sign_in_invalid_credential_failure_reason": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn’t verify your Google credentials"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos verificar tus credenciales de Google"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos verificar tus credenciales de Google"
          }
        }
      }
    },
    "google_sign_in_invalid_credential_failure_recovery_suggestion": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try signing in again"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inténtalo de nuevo"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Inténtalo de nuevo"
          }
        }
      }
    },
    "google_sign_in_network_failure_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network error"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de red"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de red"
          }
        }
      }
    },
    "google_sign_in_network_failure_reason": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn’t reach the sign-in service"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos conectar con el servicio de inicio de sesión"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos conectar con el servicio de inicio de sesión"
          }
        }
      }
    },
    "google_sign_in_network_failure_recovery_suggestion": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check your connection and try again"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa tu conexión e inténtalo de nuevo"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa tu conexión e inténtalo de nuevo"
          }
        }
      }
    },
    "invalid_credential_sign_in_failure_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid credentials provided"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Credenciales inválidas"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Credenciales no válidas"
          }
        }
      }
    },
    "invalid_credential_sign_in_failure_reason": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That email or password doesn’t seem right"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que ese correo o contraseña no es correcto"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que ese correo o esa contraseña no son correctos"
          }
        }
      }
    },
    "invalid_credential_sign_in_failure_recovery_suggestion": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Double-check your credentials and give it another go"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica que tu correo y contraseña estén bien escritos"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba que tu correo y contraseña estén bien escritos"
          }
        }
      }
    },
    "invalid_email_link_sign_in_failure_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invalid sign-in link"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enlace de inicio de sesión inválido"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Enlace de inicio de sesión no válido"
          }
        }
      },
      "extractionState": "manual"
    },
    "invalid_email_link_sign_in_failure_reason": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The sign-in link you clicked is either invalid or has expired"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El enlace de inicio de sesión en el que hiciste clic es inválido o ha expirado"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El enlace de inicio de sesión en el que has hecho clic no es válido o ha caducado"
          }
        }
      },
      "extractionState": "manual"
    },
    "invalid_email_link_sign_in_failure_recovery_suggestion": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please request a new sign-in link. If you're experiencing issues repeatedly, contact our support team for further assistance"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, solicita un nuevo enlace de inicio de sesión. Si este problema se repite, contacta a nuestro equipo de soporte para obtener más ayuda"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, solicita un nuevo enlace de inicio de sesión. Si el problema se repite, contacta con nuestro equipo de soporte para obtener más ayuda"
          }
        }
      },
      "extractionState": "manual"
    },
    "no_recovery_password_warning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you forgot your password, I can’t help with recovery just yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si olvidaste tu contraseña, aún no puedo ayudarte con eso"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Si has olvidado tu contraseña, aún no puedo ayudarte con la recuperación"
          }
        }
      }
    },
    "password_label": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Contraseña"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Contraseña"
          }
        }
      }
    },
    "password_validation_failure_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Password must be between 8–16 characters and include at least one uppercase letter, one lowercase letter, one number, and one special character"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La contraseña debe tener entre 8 y 16 caracteres e incluir al menos una letra mayúscula, una letra minúscula, un número y un carácter especial"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "La contraseña debe tener entre 8 y 16 caracteres e incluir al menos una letra mayúscula, una letra minúscula, un número y un carácter especial"
          }
        }
      }
    },
    "send_sign_in_link_to_email_too_many_requests_failure_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Email sign-in is temporarily unavailable"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El inicio de sesión por correo no está disponible temporalmente"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El inicio de sesión por correo no está disponible temporalmente"
          }
        }
      }
    },
    "send_sign_in_link_to_email_too_many_requests_failure_reason": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have exceeded the daily limit for email sign-in requests"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has superado el límite diario de solicitudes de inicio de sesión por correo"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Has superado el límite diario de solicitudes de inicio de sesión por correo"
          }
        }
      }
    },
    "send_sign_in_link_to_email_too_many_requests_failure_recovery_suggestion": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please try again in a few hours"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inténtalo de nuevo en unas horas"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a intentarlo dentro de unas horas"
          }
        }
      }
    },
