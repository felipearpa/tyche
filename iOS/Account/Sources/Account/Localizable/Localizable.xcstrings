    },
    "success_login_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Congratulations! You\\'re in the game and ready to place your bet. Let the fun begin!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Felicidades! Has iniciado sesión correctamente y estás listo para hacer tu apuesta. ¡Que empiece la diversión!"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Enhorabuena! Has iniciado sesión correctamente y ya puedes hacer tu apuesta. ¡Que empiece la diversión!"
          }
        }
      }
    },
    "verification_email_sent_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the link in your email to sign in"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el enlace en el correo para entrar"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca el enlace en el correo para entrar"
          }
        }
      }
    },
    "verification_email_sent_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We sent you a link"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te enviamos un enlace"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Te enviamos un enlace"
          }
        }
      }
    },
    "verification_email_sent_warning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure to open it on this device"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de abrirlo desde este teléfono"
          }
        },
        "es-ES": {
