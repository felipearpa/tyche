{
  "sourceLanguage": "en",
  "strings": {
    "account_verified_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap below to start playing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca abajo para empezar a jugar"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca abajo para empezar a jugar"
          }
        }
      }
    },
    "account_verified_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're verified"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya estás verificado"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya estás verificado"
          }
        }
      }
    },
    "continue_action": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue"
          }
        },
        "es": {
          "stringUnit": {
