    "delete_pool_alert_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete the pool and every gambler's bets. This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará la polla y las apuestas de todos los participantes de forma permanente. Esta acción no se puede deshacer."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará la quiniela y las apuestas de todos los participantes de forma permanente. Esta acción no se puede deshacer."
          }
        }
      }
